Bootstrap: docker
From: continuumio/miniconda3:4.12.0

%labels
    Maintainer sdweave2@ncsu.edu
    Source https://github.com/jessieren/DeepVirFinder
    Version 1.0

%help
    DeepVirFinder — identify viral sequences from metagenomic data using deep learning (CNN).

    Usage:
        apptainer run DeepVirFinder-1.0.sif -i INPUT_FA [-o OUTPUT_DIR] [-l CUTOFF_LEN] [-c CORE_NUM] [-m MODDIR]

    Options:
        -i INPUT_FA     Input fasta file (required)
        -o OUTPUT_DIR   Output directory (default: same directory as input)
        -l CUTOFF_LEN   Minimum sequence length to predict; shorter sequences skipped (default: 1)
        -c CORE_NUM     Number of parallel cores (default: 1)
        -m MODDIR       Model directory (default: /opt/DeepVirFinder/models)

    Example:
        apptainer run DeepVirFinder-1.0.sif -i contigs.fa -o results/ -l 300 -c 4

%post
    export DEBIAN_FRONTEND=noninteractive

    # Hazel bind-mount points
    mkdir -p /rs1 /share /home /usr/local/usrapps

    # Clone repo — bundled models under ./models are required at runtime
    git clone --depth 1 --branch master https://github.com/jessieren/DeepVirFinder /opt/DeepVirFinder

    # Create conda env with pinned legacy stack required by the tool
    conda create -y -n dvf -c defaults \
        python=3.6 \
        numpy \
        theano=1.0.3 \
        keras=2.2.4 \
        scikit-learn \
        biopython \
        h5py=2.10.0 \
        mkl-service=2.4.0

    conda clean -afy

%environment
    export PATH="/opt/conda/envs/dvf/bin:$PATH"
    export CONDA_DEFAULT_ENV=dvf
    export DVF_HOME=/opt/DeepVirFinder

%runscript
    exec python /opt/DeepVirFinder/dvf.py "$@"

%test
    python /opt/DeepVirFinder/dvf.py --help
