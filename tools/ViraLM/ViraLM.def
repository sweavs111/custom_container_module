Bootstrap: docker
From: ubuntu:22.04

%labels
    Maintainer sdweave2@ncsu.edu
    Source https://github.com/ChengPENG-wolf/ViraLM
    Version b7a6f4e

%help
    ViraLM — Viral Language Model for virus identification from metagenomic
    data. Uses a genome foundation model to distinguish viral genomes from
    other organisms in assembled contigs.

    Usage:
        apptainer run ViraLM-b7a6f4e.sif --input INPUT_FA --output OUTPUT_PTH --database DATABASE_PATH [options]

    Options:
        --input INPUT_FA        Input file in FASTA format
        --output OUTPUT_PTH     Path of the output directory
        --filename FILENAME     Custom name for output files (optional)
        --database DATABASE     Model directory
        --len LEN                Predict only for sequences >= len bp (default: 500)
        --batch_size BATCH_SIZE  Batch size for prediction (default: 16)
        --threshold THRESHOLD    Threshold for prediction (default: 0.5)
        --force                  Force overwrite of the output directory if it exists

    Note:
        The pretrained model/database is not bundled in this image (large,
        versioned separately by upstream). Download it once on a login node
        per the upstream README (gdown + tar -xzvf) and pass its path via
        --database.

    Example:
        apptainer run ViraLM-b7a6f4e.sif --input test.fasta --output result --database /path/to/database --len 500 --threshold 0.5

%post
    export DEBIAN_FRONTEND=noninteractive

    # Hazel bind-mount points
    mkdir -p /rs1 /share /home /usr/local/usrapps

    # System packages
    apt-get update -qq && \
        apt-get install -y --no-install-recommends \
            python3 \
            python3-pip \
            git \
            ca-certificates && \
        apt-get clean && \
        rm -rf /var/lib/apt/lists/*

    # Install ViraLM's real dependencies (discovered from source imports;
    # versions pinned from the repo's own viralm.yaml conda environment file)
    pip3 install --no-cache-dir \
        biopython==1.83 \
        datasets==2.16.1 \
        numpy==1.24.4 \
        torch==2.0.1 \
        transformers==4.29.2

    # Clone ViraLM at the pinned commit (no release tags exist upstream)
    git clone https://github.com/ChengPENG-wolf/ViraLM.git /opt/ViraLM
    cd /opt/ViraLM && git checkout b7a6f4e

    # ViraLM ships a flat viralm.py script with no console-script entry
    # point — wrap it so container-mod gets a single bare executable name
    cat > /usr/local/bin/viralm << 'EOF'
#!/bin/bash
exec python3 /opt/ViraLM/viralm.py "$@"
EOF
    chmod +x /usr/local/bin/viralm

%environment
    export DEBIAN_FRONTEND=noninteractive

%runscript
    exec viralm "$@"

%test
    viralm --help
