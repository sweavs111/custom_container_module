Bootstrap: docker
From: condaforge/miniforge3:24.3.0-0

%labels
    Maintainer sdweave2@ncsu.edu
    Source https://github.com/bhattlab/phanta
    Version 1.1.1

%help
    Phanta — Snakemake pipeline to rapidly quantify taxa from all domains of
    life (bacteria, archaea, eukaryotes, and viruses/phages) directly from
    short-read human gut metagenomes, using Kraken2/Bracken against a
    virus-inclusive reference database.

    Usage:
        apptainer run Phanta.sif -o OUTPUT_DIR [options]

    Options (see run_phanta.py --help for the full list):
        -i INPUT_DIR       Directory of input fastq(.gz) files
        -s SAMPLE_SHEET    Pre-built tab-delimited sample sheet
        -d DB_DIR          Path to Phanta reference database
        -o OUTPUT_DIR      Destination folder for results (required)
        -c CORES           Cores for Snakemake
        --run              Actually launch the pipeline (otherwise dry-run)

    Example:
        apptainer run Phanta.sif --help

%post
    export DEBIAN_FRONTEND=noninteractive

    # Hazel bind-mount points
    mkdir -p /rs1 /share /home /usr/local/usrapps

    apt-get update -qq && \
        apt-get install -y --no-install-recommends \
            git \
            ca-certificates && \
        apt-get clean && \
        rm -rf /var/lib/apt/lists/*

    # Conda environment — exact package list taken from phanta_env.yaml
    # in the bhattlab/phanta repo (tag v1.1.1), not re-derived from the README
    mamba create -n phanta -y -c conda-forge -c bioconda \
        bracken \
        pandas \
        r-base \
        r-stringr \
        r-dplyr \
        snakemake=7.15.2 \
        kraken2=2.1.6
    mamba clean -afy

    # Pin the pipeline source to the same release the env file was shipped with
    git clone --depth 1 --branch v1.1.1 https://github.com/bhattlab/phanta.git /opt/phanta

%environment
    export DEBIAN_FRONTEND=noninteractive
    export PATH=/opt/conda/envs/phanta/bin:$PATH
    export PHANTA_DIR=/opt/phanta

%runscript
    exec python3 /opt/phanta/run_phanta.py "$@"

%test
    python3 /opt/phanta/run_phanta.py --help
