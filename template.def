Bootstrap: docker
From: ubuntu:22.04

# ------------------------------------------------------------
# TEMPLATE — copy to <ToolName>/<ToolName>.def and fill in
# all <PLACEHOLDER> values before building.
#
# Build (cache/tmp dirs MUST be off $HOME — see config.sh):
#   module load apptainer
#   export APPTAINER_BINDPATH=""
#   export APPTAINER_CACHEDIR="/share/brc/$USER/.apptainer/cache"
#   export APPTAINER_TMPDIR="/share/brc/$USER/.apptainer/tmp"
#   apptainer build <ToolName>/<ToolName>.sif <ToolName>/<ToolName>.def
#
# Pick ONE install pattern below. Verified against real builds — see
# CLAUDE.md "Lessons from empirical builds" for why these specific
# patterns were chosen over the alternatives.
#
# Pattern 0 — Upstream ships its own container def (check the repo for
#   Dockerfile / Singularity*.def / apptainer/*.def / singularity/*.def
#   FIRST, before writing anything from scratch). Adapt it: keep its
#   install logic, add our %labels/Maintainer and the Hazel bind-mount
#   mkdir line. Do not re-derive install steps the upstream authors
#   already solved.
#
#   STALENESS CHECK before adopting it as-is: an old/abandoned upstream
#   Dockerfile can look fine and still be broken today. Watch for EOL base
#   image tags (ubuntu:14.04/16.04, debian:8 or older), continuumio/miniconda
#   + classic `conda` (its bundled OpenSSL can no longer TLS-handshake with
#   anaconda.org — silently fails since %post has no set -e, see below), or
#   bare http:// installer URLs. If any are present, keep upstream's install
#   *logic* (what to install, in what order) but swap in this project's own
#   validated primitives (a current Ubuntu LTS base, or Pattern 4's
#   miniforge3 + mamba for any conda/bioconda packages) instead of copying
#   the literal rotted commands. See CLAUDE.md lessons 6-7.
#
# Pattern 1 — PyPI release, modern wheel available (From: ubuntu:22.04).
#   create_def_file.sh no longer auto-checks PyPI (its only input is a
#   GitHub URL, not a name to search with) — only pick this pattern if
#   the README itself explicitly confirms a PyPI release:
#   apt-get install python3 python3-pip git ca-certificates
#   pip3 install --no-cache-dir <Tool>==<Version>
#
# Pattern 2 — GitHub source with setup.py/pyproject.toml, no PyPI release
#   (From: ubuntu:22.04):
#   apt-get install python3 python3-pip build-essential git ca-certificates
#   pip3 install --no-cache-dir git+<URL>@<tag>
#
# Pattern 3 — GitHub source, NO packaging file at all (no setup.py,
#   pyproject.toml, or requirements.txt). Do NOT guess dependencies from
#   the README — grep the actual `import`/`from` statements in the repo's
#   .py files for the real dependency list (see create_def_file.sh, which
#   does this automatically). Only add build-essential if a discovered
#   dependency has no prebuilt wheel.
#   apt-get install python3 python3-pip git ca-certificates [+ build-essential if needed]
#   pip3 install --no-cache-dir <deps discovered from imports>
#   git clone --depth 1 --branch <tag> <URL> /opt/<Tool>
#   If the tool has no console-script entry point, %runscript's <command>
#   MUST still be a single bare name with no spaces or paths (see the
#   %runscript rule below) — a raw `python3 /opt/<Tool>/<script>.py`
#   invocation is NOT valid here, it breaks container-mod's Programs
#   parsing and its generated exec wrappers (both expect one in-container
#   executable name resolvable via `command -v`). Create a wrapper in
#   %post instead:
#     cat > /usr/local/bin/<tool> << 'EOF'
#     #!/bin/bash
#     exec python3 /opt/<Tool>/<script>.py "$@"
#     EOF
#     chmod +x /usr/local/bin/<tool>
#   then %runscript/%test invoke the bare `<tool>` name. (See
#   tools/fastaaiv2/fastaaiv2.def for a real example of this pattern.)
#
# Pattern 4 — Distributed via bioconda/conda-forge:
#   From: condaforge/miniforge3:24.3.0-0   (NOT continuumio/miniconda3 —
#     its classic solver can hang indefinitely on the combined
#     bioconda+conda-forge index; miniforge3 ships mamba/libmamba and
#     solves the same request in minutes)
#   mamba create -n <tool> -y -c conda-forge -c bioconda <pkg>=<ver>
#   mamba clean -afy
#   Activate in %environment: prepend /opt/conda/envs/<tool>/bin to PATH
# ------------------------------------------------------------

%labels
    Maintainer sdweave2@ncsu.edu
    Source <UPSTREAM_URL>
    Version <VERSION>

%help
    <TOOL> — <one-line description>

    Usage:
        apptainer run <ToolName>.sif [options]

    Options:
        # Document key flags here

    Example:
        apptainer run <ToolName>.sif --help

%post
#!/bin/bash
    set -e
    # The shebang above MUST be the literal first line with zero leading
    # whitespace — Apptainer runs %post under /bin/sh (dash) by default,
    # and dash's 'set' doesn't support '-o pipefail' (fails immediately
    # with "Illegal option -o pipefail" if attempted there). The bash
    # shebang makes 'set -o pipefail' safe to add below if any install
    # line pipes through another command. Apptainer does NOT fail the
    # build when a %post command fails on its own — without set -e, a
    # broken install step (e.g. a dead installer URL, an SSL failure)
    # silently continues, and the build reports success with a .sif that's
    # missing whatever failed to install. See CLAUDE.md lessons 6, 10.
    export DEBIAN_FRONTEND=noninteractive

    # Hazel bind-mount points
    mkdir -p /rs1 /share /home /usr/local/usrapps

    # System packages — add or remove as needed
    apt-get update -qq && \
        apt-get install -y --no-install-recommends \
            python3 \
            python3-pip \
            git \
            ca-certificates && \
        apt-get clean && \
        rm -rf /var/lib/apt/lists/*

    # Install <TOOL> — pick the one pattern above that matches this tool
    # and delete the rest of these comments.

%environment
    export DEBIAN_FRONTEND=noninteractive
    # Add PATH or other runtime vars here if needed

%runscript
    # <command> must be a single bare executable name (no spaces, no
    # paths, no interpreter prefix) resolvable via `command -v` inside
    # the built container — see the Pattern 3 note above if the tool has
    # no console-script entry point.
    exec <command> "$@"

%test
    # --help/-h doesn't always exit 0 — some CLI frameworks (notably Perl's
    # Getopt::Long + Pod::Usage, where pod2usage() exits 2 by design) treat
    # help text as a usage error, not success. Check how the tool's help
    # flag actually terminates before relying on its exit code; if it's
    # nonzero by design, test on output content instead, e.g.:
    #   <command> --help 2>&1 | grep -q "<distinctive string from the help text>"
    # See CLAUDE.md lesson 8.
    <command> --help
