Bootstrap: docker
From: ubuntu:22.04

%labels
	Author: Seth Weaver
	Purpose: Test container builds with apptainer

%help
	This container is a test for apptainer build

%files
	/rs1/shares/brc/admin/containers/build_container/test_container/scripts/test_script.sh /usr/local/bin/test_script.sh
	/rs1/shares/brc/admin/containers/build_container/test_container/scripts/test_python.py /usr/local/bin/test_python.py
	/rs1/shares/brc/admin/containers/build_container/test_container/scripts/requirements.txt /usr/local/bin/requirements.txt

%post
	# --- Bind mount
# ----------------------------------------------------
	mkdir -p /rs1/shares/brc/admin

	# --- System packages
# ----------------------------------------------------
	apt-get update -qq
	apt-get install -y --no-install-recommends \
		build-essential \
		curl \
		git \
		libhdf5-dev \
		python3 \
		python3-pip

	# --- Specific packages
# ---------------------------------------------------
	pip3 install --no-cache-dir -r /usr/local/bin/requirements.txt
	
	# --- Clean-up
# ---------------------------------------------------
	chmod +x /usr/local/bin/test_script.sh
	apt-get clean && rm -rf /var/lib/apt/lists/*

%runscript
	exec /usr/local/bin/test_script.sh "$@"

%test
	python3 -c "import numpy; print('OK')"
